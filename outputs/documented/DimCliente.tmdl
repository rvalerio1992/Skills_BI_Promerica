	partition DimCliente = m
		mode: import
		queryGroup: Dimensiones
		source =
				let
				   // Data Steward: Nancy Rebeca García Ureña
				   Source = Sql.Database("synw-modeling-prod-westus2-001-ondemand.sql.azuresynapse.net", "gold", [Query="SELECT #(lf)    COD_CLIENTE, #(lf)    NOMBRE,#(lf)    TIPO_CLIENTE,#(lf)    SEGMENTACION_ESTRATEGICA,#(lf)    SEGMENTACION_OPERATIVA,#(lf)    GERENCIA#(lf)FROM dbo.masteranalytics#(lf)WHERE FEC_CORTE = (#(lf)        SELECT MAX(FEC_CORTE) #(lf)        FROM dbo.masteranalytics      -- siempre trae la fecha más reciente#(lf))#(lf)  AND COD_CLIENTE <> 'SIN COD_CLIENTE';#(lf)"])
				in
				  Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegación

