/// Tabla auxiliar que agrupa medidas calculadas. [confianza: alta]
table Medidas
	lineageTag: 4e7324a5-5886-43b1-ac02-28cadeb89b39

	/// Porcentaje de cumplimiento (1 + ratio de delta). [confianza: media]
	measure 1_Complete_% = 1 + DIVIDE([1_Target_Delta], [Valor Meta], 0)
		displayFolder: Metas y Targets
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: 0ffac0bb-f7cb-4007-a8c6-a79cc1b32cf8

	/// Porcentaje de cumplimiento (1 + ratio de delta). [confianza: media]
	measure 1_Estado = 1 + DIVIDE([1_Target_Delta], [Valor Meta], 0)
		formatString: "#,##0.00"
		displayFolder: Dinámicas Internas
		lineageTag: 885ca894-3002-47c7-b69b-e5a7fce9a5b5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Espacio1 = 1
		formatString: 0
		lineageTag: 96fc2696-c8d2-44ec-9447-1d0ab409ea7d

	measure Espacio2 = 1
		formatString: 0
		lineageTag: fb92f8f4-2e60-4d91-8218-813054b1a0bc

