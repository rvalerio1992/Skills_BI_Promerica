		lineageTag: 4407e633-07ac-4c72-ae0f-854ef82dbe65

	/// [TODO: validar con negocio] [confianza: baja]
	measure TieneDatos = ```
			
			VAR _n =
			    CALCULATE (
			        COUNTROWS ( FctProductos )
			        -- asumiendo relación activa DimTipoProducto[COD_TIPO_PRODUCTO] -> FctProductos[COD_TIPO_PRODUCTO]
			    )
			RETURN IF ( _n > 0, 1, BLANK() )
			
			```
		displayFolder: Indicadores
