	measure Medida
		lineageTag: 06f1c1d6-28d0-4f7f-b39e-2cb343f3de77

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	/// Promedio ponderado con SUMX. [confianza: media]
	measure 'Tasa Ponderada' = ```
			
			VAR TasaCalc =
			    CALCULATE(
			        DIVIDE(
			            SUMX(
			                FctProductos,
			                FctProductos[TASA] * FctProductos[VALOR]
			            ),
			            SUM(FctProductos[VALOR])
			        ),
			        FILTER(
			            ALL(FctProductos[FEC_CORTE]),
			            FctProductos[FEC_CORTE] =
			                MAXX(ALL(FctProductos[FEC_CORTE]), FctProductos[FEC_CORTE])
			        )
			    )
			RETURN
			    IF(ISBLANK(TasaCalc), 0, TasaCalc)
			
			
			```
		formatString: 0.00
		displayFolder: Indicadores
		lineageTag: f9a2764b-0584-44d6-9eae-3800ee2c6c2b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

