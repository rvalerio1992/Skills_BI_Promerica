	partition '⚙ Medidas' = m
		mode: import
		queryGroup: Medidas
		source =
				let
				    Origen = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Stub = _t]),
				    #"Columnas quitadas" = Table.RemoveColumns(Origen,{"Stub"})
				in
				    #"Columnas quitadas"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegación

