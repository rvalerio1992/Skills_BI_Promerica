	/// Ratio entre [Valor MoM] y [Valor Mes Anterior], seguro ante divisor cero. [confianza: alta]
	measure 1_MoM_% = DIVIDE([Valor MoM], [Valor Mes Anterior], 1)
		displayFolder: Comparativos
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: d5b1af4f-1693-4469-bf8d-fc88fdb4798c

		changedProperty = IsHidden

