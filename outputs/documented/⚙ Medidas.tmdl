	/// Fecha máxima disponible, ignorando filtros de contexto. [confianza: alta]
	measure 'Valor Cierre Año Anterior' = ```
			
			CALCULATE(
			    [Valor Métrica Seleccionada], 
			    FILTER(
			        'FctProductos', 
			        'FctProductos'[FEC_CORTE] = DATE(YEAR(CALCULATE(MAX('FctProductos'[FEC_CORTE]), ALL('FctProductos'))) - 1, 12, 31)
			        )
			)
			
			```
		formatString: "\$#,0.00"
		displayFolder: Comparativos
		lineageTag: 24813518-ff57-4f98-9b3c-f618eb20f7e9

