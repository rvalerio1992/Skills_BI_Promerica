	partition DimTipoProducto = m
		mode: import
		queryGroup: Dimensiones
		source =
				let
				    // Data Steward: Nancy Rebeca García Ureña
				    Source = Sql.Database("synw-modeling-prod-westus2-001-ondemand.sql.azuresynapse.net", "gold", [Query="#(lf)WITH base AS ( #(lf)#(lf)    SELECT #(lf)#(lf)        COD_TIPO_PRODUCTO, #(lf)#(lf)        NOM_PRODUCTO, #(lf)#(lf)        CASE #(lf)#(lf)            WHEN COD_TIPO_PRODUCTO IN ('CE_056','CE_057') THEN 'CUENTA ALTO RENDIMIENTO' #(lf)#(lf)            ELSE DESC_PRODUCTO #(lf)#(lf)        END AS DESC_PRODUCTO, #(lf)#(lf)        TIPO_PRODUCTO AS TIPO_PRODUCTO_ORIG, #(lf)#(lf)        TIPO_PRODUCTO_CORE, #(lf)#(lf)        TIPO_NECESIDAD, #(lf)#(lf)        PRODUCTO_CORE_FLAG, #(lf)#(lf)        VERDE_FLAG, #(lf)#(lf)        CASE #(lf)#(lf)            WHEN LEFT(COD_TIPO_PRODUCTO, 3) IN ('CE_', 'CDI') THEN 'SALDO PASIVO' #(lf)#(lf)            WHEN LEFT(COD_TIPO_PRODUCTO, 3) IN ('PR_', 'TC_', 'XF_') THEN 'SALDO ACTIVO' #(lf)#(lf)            ELSE 'NO APLICA' #(lf)#(lf)        END AS TIPO_SALDO #(lf)#(lf)    FROM dbo.dimtipoproducto #(lf)#(lf)), deriv AS ( #(lf)#(lf)    SELECT #(lf)#(lf)        COD_TIPO_PRODUCTO, #(lf)#(lf)        NOM_PRODUCTO, #(lf)#(lf)        DESC_PRODUCTO, #(lf)#(lf)        TIPO_PRODUCTO_ORIG, #(lf)#(lf)        TIPO_PRODUCTO_CORE, #(lf)#(lf)        TIPO_NECESIDAD, #(lf)#(lf)        PRODUCTO_CORE_FLAG, #(lf)#(lf)        VERDE_FLAG, #(lf)#(lf)        TIPO_SALDO, #(lf)#(lf)        CASE #(lf)#(lf)            WHEN LEFT(COD_TIPO_PRODUCTO, 3) IN ('TC_', 'XF_') THEN 'TARJETA DE CREDITO' #(lf)#(lf)            WHEN LEFT(COD_TIPO_PRODUCTO, 3) = 'PR_' THEN 'CREDITOS' #(lf)#(lf)            ELSE UPPER(TIPO_PRODUCTO_ORIG) #(lf)#(lf)        END AS TIPO_PRODUCTO_STEP, #(lf)#(lf)        CASE #(lf)#(lf)            WHEN COD_TIPO_PRODUCTO IN ('CE_056','CE_057') THEN 'ALTO RENDIMIENTO' #(lf)#(lf)            WHEN LEFT(COD_TIPO_PRODUCTO, 3) = 'CDI' THEN #(lf)#(lf)                CASE #(lf)#(lf)                    WHEN DESC_PRODUCTO COLLATE Latin1_General_CI_AI LIKE '%DESMATERIALIZADOS%' THEN 'DESMATERIALIZADOS' #(lf)#(lf)                    WHEN DESC_PRODUCTO COLLATE Latin1_General_CI_AI LIKE '%EMISIONES%' THEN 'EMISIONES SUBORDINADOS' #(lf)#(lf)                    WHEN DESC_PRODUCTO COLLATE Latin1_General_CI_AI LIKE '%MACROTITULOS%' THEN 'MACROTITULOS' #(lf)#(lf)                    ELSE 'OTROS' #(lf)#(lf)                END #(lf)#(lf)            ELSE TIPO_PRODUCTO_ORIG #(lf)#(lf)        END AS SUBTIPO_PRODUCTO_STEP #(lf)#(lf)    FROM base #(lf)#(lf)), final_ AS ( #(lf)#(lf)    SELECT #(lf)#(lf)        COD_TIPO_PRODUCTO, #(lf)#(lf)        NOM_PRODUCTO, #(lf)#(lf)        DESC_PRODUCTO, #(lf)#(lf)        /* TIPO_PRODUCTO final con reemplazos */ #(lf)#(lf)        CASE #(lf)#(lf)            WHEN TIPO_PRODUCTO_STEP = 'PLAN METAS' THEN 'CUENTA DE EFECTIVO' #(lf)#(lf)            WHEN TIPO_PRODUCTO_STEP IN ('CREDITO HIPOTECARIO','CREDITO PRENDARIO','CREDITO OTROS') THEN 'CREDITO' #(lf)#(lf)            ELSE TIPO_PRODUCTO_STEP #(lf)#(lf)        END AS TIPO_PRODUCTO, #(lf)#(lf)        /* SUBTIPO_PRODUCTO final con reemplazos */ #(lf)#(lf)        CASE #(lf)#(lf)            WHEN SUBTIPO_PRODUCTO_STEP = 'CUENTA DE EFECTIVO' THEN 'CORRIENTE/AHORRO' #(lf)#(lf)            WHEN SUBTIPO_PRODUCTO_STEP = 'TARJETA DE CREDITO' THEN 'REVOLVENTE' #(lf)#(lf)            ELSE SUBTIPO_PRODUCTO_STEP #(lf)#(lf)        END AS SUBTIPO_PRODUCTO, #(lf)#(lf)        TIPO_PRODUCTO_CORE, #(lf)#(lf)        TIPO_NECESIDAD, #(lf)#(lf)        PRODUCTO_CORE_FLAG, #(lf)#(lf)        VERDE_FLAG, #(lf)#(lf)        TIPO_SALDO #(lf)#(lf)    FROM deriv #(lf)#(lf)) #(lf)#(lf)SELECT #(lf)#(lf)    COD_TIPO_PRODUCTO, #(lf)#(lf)    NOM_PRODUCTO, #(lf)#(lf)    DESC_PRODUCTO, #(lf)#(lf)    TIPO_PRODUCTO, #(lf)#(lf)    SUBTIPO_PRODUCTO, #(lf)#(lf)    TIPO_PRODUCTO_CORE, #(lf)#(lf)    TIPO_NECESIDAD, #(lf)#(lf)    PRODUCTO_CORE_FLAG, #(lf)#(lf)    VERDE_FLAG, #(lf)#(lf)    TIPO_SALDO, #(lf)#(lf)    CASE #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'EMISIONES SUBORDINADOS' THEN 5 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'MACROTITULOS' THEN 6 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'OTROS' THEN 7 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'DESMATERIALIZADOS' THEN 4 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'PLAN METAS' THEN 3 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'ALTO RENDIMIENTO' THEN 2 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'CORRIENTE/AHORRO' THEN 1 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'SBD' THEN 14 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'COMERCIAL' THEN 10 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'NAP Y MICROCREDITOS' THEN 16 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'EXTRA FINANCIAMIENTOS' THEN 9 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'REVOLVENTE' THEN 8 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'PRENDARIO' THEN 13 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'HIPOTECARIO' THEN 12 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'PERSONAL PREFERENTE' THEN 17 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'OTROS (FACTORING & PSA)' THEN 15 #(lf)#(lf)        WHEN SUBTIPO_PRODUCTO = 'EMPRESARIAL' THEN 11 #(lf)#(lf)        ELSE 999 #(lf)#(lf)    END AS ORDEN #(lf)#(lf)FROM final_; #(lf)#(lf)"])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegación

