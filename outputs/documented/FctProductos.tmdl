		annotation SummarizationSetBy = Automatic

	column PERIODO_FLAG = ```
			
			VAR Fecha = 'FctProductos'[FEC_CORTE]
			VAR Hoy   = TODAY()
			
			VAR MesActual     = YEAR(Fecha) = YEAR(Hoy)
			                 && MONTH(Fecha) = MONTH(Hoy)
			
			VAR MesAnterior   = YEAR(Fecha) = YEAR(EOMONTH(Hoy,-1))
			                 && MONTH(Fecha) = MONTH(EOMONTH(Hoy,-1))
			
			VAR Interanual    = YEAR(Fecha) = YEAR(Hoy) - 1
			                 && MONTH(Fecha) = MONTH(Hoy)
			
			VAR DicAnterior   = YEAR(Fecha) = YEAR(Hoy) - 1
			                 && MONTH(Fecha) = 12            -- diciembre
			
			RETURN
			    IF(MesActual || MesAnterior || Interanual || DicAnterior, 1, 0)
			
			```
		formatString: 0
		lineageTag: 555b5b8c-ce41-4e16-8c2d-cc797a5a9545
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column TIPO_PRODUCTO = ```
			RELATED(DimTipoProducto[TIPO_PRODUCTO])
			
			
			```
		lineageTag: a1fbe905-0cf0-49f9-97b7-c96ba95acc66
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

