	column NIVEL_0 = "VALOR TOTAL"//UPPER([Titulo Medida])
		lineageTag: 7b40604e-911c-488c-b612-605409fd5aac
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column NIVEL_1 = ```
			
			VAR _cod = [COD_PRODUCTO]
			VAR _sub = UPPER ( TRIM ( [SUBTIPO_PRODUCTO] ) )
			VAR _dir = RELATED ( DimPromotor[DIRECCION] )
			RETURN
			SWITCH (
			    TRUE(),
			    LEFT ( _cod, 2 ) = "TC" || LEFT ( _cod, 2 ) = "XF", "BANCA PERSONAS",
			
			    -- SUBTIPO_PRODUCTO → Resultado
			    _sub IN { "EXTRA FINANCIAMIENTOS", "REVOLVENTE", "PERSONAL PREFERENTE", "HIPOTECARIO", "PRENDARIO" }, "BANCA PERSONAS",
			    _sub IN { "COMERCIAL", "EMPRESARIAL", "SBD"}, "BANCA EMPRESAS",
			
			    _dir = "SIN DIRECCION", "TESORERIA",
			    ISBLANK ( _dir ), "TESORERIA",
			    _dir
			)
			
			
			```
		lineageTag: 3263bbb7-c81c-444e-9235-922926128e48
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column NIVEL_2 = ```
			SWITCH(TRUE(),
			[NIVEL_1]="BANCA PERSONAS" && ISBLANK(RELATED(DimCliente[SEGMENTACION_ESTRATEGICA])), "MASIVO",
			[NIVEL_1]="BANCA PERSONAS", RELATED(DimCliente[SEGMENTACION_ESTRATEGICA]),
			[NIVEL_1]="BANCA EMPRESAS" && RELATED(DimCliente[TIPO_CLIENTE])="JURIDICA" && RELATED(DimCliente[SEGMENTACION_OPERATIVA])="ND", "PYME",
			[NIVEL_1]="BANCA EMPRESAS" && RELATED(DimCliente[TIPO_CLIENTE])="JURIDICA", RELATED(DimCliente[SEGMENTACION_OPERATIVA]), 
			[NIVEL_1]="BANCA EMPRESAS", "PYME", 
			[NIVEL_1]="BANCA PRIVADA" && RELATED(DimPromotor[GERENCIA])="BANCA PRIVADA GERENCIA","GERENCIA",
			 [NIVEL_1]="BANCA PRIVADA" && RELATED(DimPromotor[GERENCIA])="BANCA PRIVADA EJECUTIVOS","EJECUTIVOS",
			"TESORERIA")
			```
		lineageTag: 820def74-3182-484f-8459-82475844db73
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column COD_ESTADO_PRODUCTO
