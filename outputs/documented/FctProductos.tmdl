	partition FctProductos = m
		mode: import
		queryGroup: Hechos
		source =
				let
				   // Data Steward: Nancy Rebeca García Ureña
				   Source = Sql.Database("synw-modeling-prod-westus2-001-ondemand.sql.azuresynapse.net", "gold", [Query="SELECT#(lf)    FEC_CORTE,#(lf)    COD_CLIENTE,#(lf)    COD_PRODUCTO,#(lf)    COD_TIPO_PRODUCTO,#(lf)    COD_MONEDA,#(lf)    COD_PROMOTOR,#(lf)    COD_ESTADO_PRODUCTO,#(lf)    SALDO_PRODUCTO AS VALOR,#(lf)    TASA_INTERES_PRODUCTO AS TASA_INTERES#(lf)FROM #(lf)    dbo.fctproductos#(lf)WHERE#(lf)    LEFT(COD_PRODUCTO, 3) IN ('CE_', 'CDI', 'PR_', 'TC_', 'XF_')#(lf)    AND YEAR(FEC_CORTE) >= YEAR(GETDATE()) - 1#(lf)"]),
				    #"Tipo cambiado" = Table.TransformColumnTypes(Source,{{"FEC_CORTE", type date}}),
				    #"Texto recortado" = Table.TransformColumns(#"Tipo cambiado",{{"COD_PROMOTOR", Text.Trim, type text}}),
				    #"Valor reemplazado" = Table.ReplaceValue(#"Texto recortado","MSOJO_IB","MSOJ_IB",Replacer.ReplaceText,{"COD_PROMOTOR"})
				in
				  #"Valor reemplazado"

