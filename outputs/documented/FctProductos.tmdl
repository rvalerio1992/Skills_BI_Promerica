			[TASA_INTERES]<1,"[0% a 1%[",
			[TASA_INTERES]<3,"[1% a 3%[",
			[TASA_INTERES]<4,"[3% a 4%[",
			[TASA_INTERES]<5,"[4% a 5%[",
			">= 5%")
