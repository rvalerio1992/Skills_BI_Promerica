{
  // ── Agent Skills ──────────────────────────────────────────────
  "chat.useAgentSkills": true,
  "chat.agentSkillsLocations": {
    ".github/skills": true
  },

  // ── JSON / TMDL ───────────────────────────────────────────────
  "[json]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[tmdl]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },

  // ── Power BI (extensión PowerBI Studio) ───────────────────────
  "powerbi.general.workspaceFilter": [],
  "powerbi.general.apiEndpoint": "https://api.powerbi.com",

  // ── Editor general ────────────────────────────────────────────
  "editor.fontSize": 14,
  "editor.rulers": [100],
  "editor.bracketPairColorization.enabled": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.associations": {
    "*.tmdl": "tmdl",
    "*.pbir": "json",
    "*.pbip": "json"
  },

  // ── Git ───────────────────────────────────────────────────────
  "git.autofetch": true,
  "gitlens.currentLine.enabled": true
}
